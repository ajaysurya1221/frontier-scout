# Copy to .env and fill in real values for local dev.
# Never commit your real .env — it's git-ignored.

# ── Required for live scans ──────────────────────────────────────────────────
# Sonnet 4.6 powers the score + verdict + interpret passes.
# Opus 4.7 powers the optional RLAIF judge.
ANTHROPIC_API_KEY=replace-me

# ── Optional ─────────────────────────────────────────────────────────────────

# Raises GitHub REST API rate limit from 60/hr → 5000/hr. Recommended.
GITHUB_TOKEN=

# Skip the Opus judge pass to save cost (~$0.20/scan). Default: judge runs.
JUDGE_ENABLED=true

# Override the polyglot lab dispatcher's caps.
# LAB_HF_SIZE_CAP_GB=5
# LAB_RUNS_PER_DAY=10
# LAB_DAILY_USD_CAP=5
# LAB_SUBPROCESS_TIMEOUT=600

# ── Local dev only ───────────────────────────────────────────────────────────
# Override local runtime state. Defaults to ~/.frontier-scout.
# FRONTIER_SCOUT_HOME=~/.frontier-scout

# Set to 1 for legacy script dry-runs.
DRY_RUN=1
