# Copy to .env and fill in real values for local dev.
# In production, set these as Bitbucket Repository Variables (Secured).
# Never commit your real .env — it's git-ignored.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=replace-me

# ── Slack target — pick ONE ──────────────────────────────────────────────────
# Option A (RECOMMENDED): Bot token + channel ID for threaded format + auto-reactions
# Bot scopes needed: chat:write, reactions:write, commands, chat:write.customize
# SLACK_BOT_TOKEN=replace-me
# SLACK_CHANNEL_ID=C0XXXXXXXXX

# Option B: Incoming Webhook (simpler, no admin approval, single-message format only)
SLACK_WEBHOOK_URL=

# ── Optional ─────────────────────────────────────────────────────────────────
# Mem0 prior-filter and post-seed (semantic memory of past verdicts)
OPENAI_API_KEY=replace-me

# Raises GitHub REST API rate limit from 60/hr → 5000/hr
GITHUB_TOKEN=replace-me

# ── Local dev only ───────────────────────────────────────────────────────────
# Set to 1 to print Slack payload instead of sending. Pulse dedupe state
# is NOT mutated in dry-run mode.
DRY_RUN=1

# ── Production-only (set as Bitbucket Repository Variables, NOT in .env) ─────
# BB_TOKEN              — Bitbucket API token (Repositories:Write) for push-back
# AWS_ACCESS_KEY_ID     — IAM user with s3:PutObject/Delete on the mirror bucket
# AWS_SECRET_ACCESS_KEY
# AWS_REGION            — e.g. us-east-2
# S3_MIRROR_BUCKET      — e.g. ai-telemetry-mirror
# LAMBDA_FUNCTION_NAME  — e.g. ai-telemetry-slack (for the deploy-lambda pipeline)
