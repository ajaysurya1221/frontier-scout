/* Briefing TUI (v1.5.0) — one stylesheet for the whole look.

   Ported from the Claude Design handoff bundle ("Frontier Scout TUI"). The deep
   navy field, mint accent, filled verdict pills, mint section headers, and the
   bordered "next safe step" box all come from that spec.

   The root of every screen is three rows: Header (1) · Body (1fr, scrolls) ·
   Compass (1). Because Body always takes the remaining space and scrolls,
   content can never clip at any width or height. Cards are width-capped and
   centred so prose never sprawls on wide terminals and fills narrow ones.

   Custom variables are prefixed `$fs-` so they never collide with Textual's
   built-in theme variables (e.g. $panel, $border), which the framework uses in
   its own system stylesheets. */

/* ── Palette (from the design :root) ──────────────────────────────────────── */
$fs-bg: #0b1117;
$fs-panel: #0d1622;
$fs-card: #0c1a27;
$fs-border: #25405c;
$fs-border-soft: #1a2c41;
$fs-mint: #24d6a8;
$fs-mint-dim: #1b9a7a;
$fs-bright: #d9f7ff;
$fs-fg: #a9bccd;
$fs-muted: #6e8aa1;
$fs-blue: #7aa6ff;
$fs-gold: #e3c26f;
$fs-red: #ff6b6b;
$fs-sel-bg: #11241d;     /* mint at ~9% over the field */
$fs-next-bg: #0e1f1a;    /* mint at ~5% over the field */

Screen {
    background: $fs-bg;
    color: $fs-fg;
}

/* ── Header ─────────────────────────────────────────────────────────────── */
#header {
    height: 1;
    width: 100%;
    background: $fs-panel;
    color: $fs-muted;
    padding: 0 1;
}

/* ── Body — the only scrolling region ───────────────────────────────────── */
#body {
    height: 1fr;
    width: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    align-horizontal: center;
    padding: 1 1;
}

/* ── Compass — always-present one-line key hint ─────────────────────────── */
#compass {
    height: 1;
    width: 100%;
    background: $fs-panel;
    color: $fs-muted;
    padding: 0 1;
}

/* ── Cards — width-capped, centred, never fixed-height ──────────────────── */
.card {
    width: 1fr;
    max-width: 80;
    height: auto;
    padding: 0 1;
}

/* ── Radar — centred, decorative ────────────────────────────────────────── */
.radar {
    width: auto;
    height: auto;
    content-align: center middle;
    color: $fs-mint;
    padding: 0 0 1 0;
}

/* ── Splash hero — centred wordmark + tagline ───────────────────────────── */
.hero {
    width: auto;
    height: auto;
    content-align: center middle;
    text-align: center;
    color: $fs-bright;
    text-style: bold;
}
.hero-sub {
    width: auto;
    height: auto;
    content-align: center middle;
    text-align: center;
    color: $fs-muted;
    padding: 1 0 0 0;
}

/* ── Kicker (provider · ready) above the home hero ──────────────────────── */
.kicker {
    width: 1fr;
    max-width: 80;
    height: auto;
    color: $fs-mint;
    text-style: bold;
    padding: 0 0 1 0;
}

/* ── Verdict-pill ribbon line + light-action result banners ─────────────── */
.ribbon {
    width: 1fr;
    max-width: 80;
    height: auto;
    padding: 0 0 1 0;
}

.title {
    text-style: bold;
    color: $fs-bright;
    width: 1fr;
    max-width: 80;
    height: auto;
    padding: 0 0 1 0;
}

.prose {
    width: 1fr;
    max-width: 80;
    height: auto;
    padding: 0 0 1 0;
}

/* Mint uppercase section header, the design's `.block-h` */
.block-h {
    color: $fs-mint;
    text-style: bold;
    width: 1fr;
    max-width: 80;
    height: auto;
}

/* The bordered "next safe step" callout (design `.next-step`) */
.next-step {
    width: 1fr;
    max-width: 80;
    height: auto;
    background: $fs-next-bg;
    border-left: thick $fs-mint;
    padding: 0 1;
    margin: 0 0 1 0;
}

.dim { color: $fs-muted; }

.dots {
    width: 1fr;
    max-width: 80;
    height: auto;
    color: $fs-muted;
    content-align: center middle;
}

/* ── Home / menu rows ───────────────────────────────────────────────────── */
.menu-row {
    width: 1fr;
    max-width: 80;
    height: auto;
    padding: 0 1;
}
.menu-row.sel {
    background: $fs-sel-bg;
    color: $fs-bright;
    text-style: bold;
}

/* ── Explore / settings input ───────────────────────────────────────────── */
Input {
    width: 1fr;
    max-width: 80;
    border: round $fs-border-soft;
    background: $fs-card;
}
Input:focus {
    border: round $fs-mint;
}

/* ── The graceful floor for tiny terminals ──────────────────────────────── */
#too-small {
    display: none;
    width: 100%;
    height: 100%;
    content-align: center middle;
    color: $fs-gold;
}

Screen.tiny #header,
Screen.tiny #body,
Screen.tiny #compass {
    display: none;
}
Screen.tiny #too-small {
    display: block;
}
